# Copy this to .env.local and fill in values from your Supabase project.
# Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: chapter-facing strings (see src/lib/chapterConfig.ts)
NEXT_PUBLIC_CHAPTER_NAME=Marvin Ridge High School HOSA
NEXT_PUBLIC_CHAPTER_BRAND_KICKER=MRHS HOSA
NEXT_PUBLIC_CHAPTER_MASCOT_LINE=Mavericks
NEXT_PUBLIC_YEAR_LABEL=2025-2026
NEXT_PUBLIC_COMMUNITY_SERVICE_EMAIL=officer@example.com

# Optional copy overrides (pipe-separated for NEXT_PUBLIC_TRUST_BULLETS)
# NEXT_PUBLIC_PRODUCT_TAGLINE=Your one-line pitch.
# NEXT_PUBLIC_TRUST_BULLETS=First bullet|Second bullet
# NEXT_PUBLIC_LOGIN_DESCRIPTION=…
# NEXT_PUBLIC_SIGNUP_DESCRIPTION=…
# NEXT_PUBLIC_APP_META_DESCRIPTION=…
# NEXT_PUBLIC_TRACKER_FOOTNOTE=…
